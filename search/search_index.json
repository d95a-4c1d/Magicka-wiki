{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"]},"docs":[{"location":"","title":"\u7b80\u4ecb","text":"<p>\u6211\u4eec\u8bbe\u60f3\u4e00\u6b3e\u4ee5\u7b80\u7b14\u753b\u548c\u7172\u6c64\u9a71\u52a8\u7684\u6cd5\u672f\u6218\u6597\u65c5\u884c\u6e38\u620f\u3002\u4f60\u53ef\u4ee5\u5728\u5730\u4e0a\u753b\u51fa\u5404\u79cd\u9b54\u6cd5\u9635\uff0c\u4ee5\u6b64\u6765\u5236\u9020\u3001\u4f20\u9001\u3001\u5854\u9632\u751a\u81f3\u590d\u6d3b\u961f\u53cb\u7b49\uff0c\u540c\u65f6\u901a\u8fc7\u70f9\u996a\uff08\u7172\u6c64\uff09\u5f97\u5230\u5404\u79cd\u795e\u5947\u7684\u98df\u7269\u548c\u6750\u6599\uff0c\u6700\u540e\u62b5\u8fbe\u65c5\u9014\u7684\u7ec8\u70b9\u3002</p>"},{"location":"#_2","title":"\u6e38\u620f\u6d41\u7a0b","text":"<p>\u5355\u4eba\u6216\u591a\u4eba\u6e38\u73a9\uff0c\u4ece\u540c\u4e00\u4e2a\u51fa\u751f\u70b9\u51fa\u53d1\uff0c\u5411\u7740\u7ec8\u70b9\u524d\u8fdb\u3002\u9014\u4e2d\u4f1a\u7ecf\u5386\u73af\u5883\u53d8\u5316\u3001\u602a\u7269\u88ad\u51fb\u7b49\u963b\u6320\uff0c\u9700\u8981\u5728\u884c\u52a8\u548c\u4f11\u6574\u4e2d\u505a\u51fa\u5e73\u8861\u3002\u8fd9\u5c31\u8981\u6c42\u73a9\u5bb6\u4eec\u8ba1\u5212\u5efa\u9020\u4e34\u65f6\u5e87\u62a4\u6240\u3001\u8bbe\u7f6e\u9632\u5fa1\u5de5\u4e8b\u548c\u5bfb\u627e\u98df\u7269\u7b49\u4e8b\u5b9c\u3002\u73a9\u5bb6\u4f1a\u7ecf\u8fc7\u51e0\u4e2a\u4e0d\u540c\u7684\u533a\u57df\uff0c\u533a\u57df\u4e4b\u95f4\u4ee5\u9ad8\u5899\u5206\u9694\uff0c\u73a9\u5bb6\u9700\u8981\u5728\u5173\u952e\u8282\u70b9\u6210\u529f\u5b88\u4f4f\u4e00\u6ce2\u8fdb\u653b\u624d\u80fd\u524d\u5f80\u4e0b\u4e00\u533a\u57df\u3002</p>"},{"location":"#_3","title":"\u9b54\u6cd5\u9635","text":"<p>\u4f60\u53ef\u4ee5\u8fdb\u5165\u7ed8\u753b\u6a21\u5f0f\uff0c\u7528\u624b\u6307\u6216\u9f20\u6807\u753b\u51fa\u5404\u4e2a\u9b54\u6cd5\u9635\u5bf9\u5e94\u7684\u56fe\u5f62\uff08\u53ea\u8981\u5927\u6982\u50cf\u5c31\u597d\uff09\uff0c\u6e38\u620f\u4f1a\u81ea\u52a8\u8bc6\u522b\u51fa\u76f8\u5e94\u7684\u6cd5\u672f\u3002\u7ed8\u753b\u9b54\u6cd5\u9635\u9700\u8981\u7528\u201c\u7c89\u672b\u201d\uff0c\u800c\u8981\u5c06\u51e0\u4e2a\u9b54\u6cd5\u9635\u8fde\u63a5\u8d77\u6765\u5b8c\u6210\u590d\u6742\u7684\u529f\u80fd\uff0c\u5219\u9700\u8981\u7528\u4e00\u70b9\u70b9\u8840\u6db2\u548c\u4e00\u4e9b\u9b54\u529b\u8f93\u5165\u3002</p> <p>\u76ee\u524d\u8ba8\u8bba\u4e86\u51e0\u79cd\u9b54\u6cd5\u9635\uff1a 1. \u732e\u796d\u6cd5\u9635\u3002\u5c06\u98df\u7269\u653e\u5728\u6cd5\u9635\u4e2d\u4e0a\u4f9b\uff0c\u6cd5\u9635\u5c31\u4f1a\u6d88\u8017\u98df\u7269\u5e76\u53ef\u4ee5\u901a\u8fc7\u8840\u8ff9\u4f20\u51fa\u9b54\u529b\u3002 2. \u5236\u9020\u6cd5\u9635\u3002\u7528\u539f\u6750\u6599\u7684\u7c89\u672b\u5728\u6cd5\u9635\u4e2d\u753b\u7b80\u7b14\u753b\uff0c\u5c31\u80fd\u5c06\u5176\u8f6c\u5316\u6210\u5bf9\u5e94\u7684\u7269\u54c1\u3002 3. \u590d\u5236\u6cd5\u9635\u3002\u5c06\u539f\u578b\u7269\u54c1\u653e\u5728\u6cd5\u9635\u4e2d\uff0c\u5c31\u80fd\u590d\u5236\u51fa\u4e00\u6837\u7684\u7269\u54c1\u3002\u590d\u5236\u7684\u6548\u679c\u4f9d\u6cd5\u9635\u7684\u6027\u80fd\u51b3\u5b9a\uff0c\u590d\u5236\u7684\u539f\u6599\u6765\u81ea\u8fd0\u8f93\u6cd5\u9635 4. \u4f20\u9001\u6cd5\u9635\u3002\u53ef\u4ee5\u6307\u5b9a\u4e00\u4e2aID\uff0c\u5c06\u73a9\u5bb6\u4f20\u9001\u5230\u540c\u6837ID\u7684\u53e6\u4e00\u4e2a\u4f20\u9001\u6cd5\u9635\u4e2d\u3002 5. \u89e3\u6790\u6cd5\u9635\u3002\u6d88\u8017\u4e00\u4e2a\u539f\u578b\u7269\u54c1\u540e\u89e3\u6790\u4e3a\u4e00\u5b9a\u91cf\u7684\u7c89\u672b\uff0c\u73a9\u5bb6\u5403\u4e0b\u4ee5\u540e\u53ef\u4ee5\u83b7\u5f97\u8fd9\u4e2a\u7269\u54c1\u5728\u5236\u9020\u6cd5\u9635\u7684\u914d\u65b9\u3002\u4e00\u6b21\u6027\u3002 6. \u590d\u6d3b\u6cd5\u9635\u3002\u5c06\u4e00\u4e2a\u6b7b\u4ea1\u7684\u89d2\u8272\u590d\u6d3b\u3002\u4e00\u6b21\u6027\u3002 7. \u50ac\u5316\u6cd5\u9635\u3002\u53ef\u4ee5\u8f6c\u201c\u70f9\u996a\u201d\u4e3a\u201c\u70bc\u91d1\u201d\uff0c\u5c06\u666e\u901a\u98df\u6750\u8f6c\u5316\u6210\u795e\u5947\u6d82\u6599\u3002 8. \u5730\u96f7\u6cd5\u9635\u3002\u88ab\u538b\u5230\u7684\u65f6\u5019\u731b\u70c8\u5730\u7206\u70b8\u3002\u4e00\u6b21\u6027\u3002</p> <p>\u9b54\u6cd5\u9635\u7684\u4f7f\u7528\u9700\u8981\u73a9\u5bb6\u624b\u52a8\u6fc0\u6d3b\u5e76\u4e3a\u5176\u4f9b\u80fd\u3002\u4f9b\u80fd\u7684\u65b9\u5f0f\u6709\u4e24\u79cd\uff0c\u4e00\u79cd\u662f\u76f4\u63a5\u8f6c\u5316\u73a9\u5bb6\u8eab\u4f53\u4e2d\u8574\u542b\u7684\u540c\u5316\u91cf\uff08\u53ef\u4ee5\u901a\u8fc7\u8fdb\u98df\u8865\u5145\uff09\uff0c\u53e6\u4e00\u79cd\u662f\u7531\u732e\u796d\u6cd5\u9635\u901a\u8fc7\u8840\u8ff9\u4f20\u5165\u3002</p>"},{"location":"#_4","title":"\u4f7f\u7528\u6848\u4f8b","text":"<p>\u7528\u9762\u7c89\u5728\u5730\u4e0a\u753b\u51fa\u732e\u796d\u6cd5\u9635\u3001\u5236\u9020\u6cd5\u9635\u548c\u590d\u5236\u6cd5\u9635\u540e\u7528\u8840\u6db2\u8fde\u63a5\uff0c\u5728\u732e\u796d\u6cd5\u9635\u4e0a\u4f9b\u4e00\u4e2a\u9c8d\u9c7c\u7f50\u5934\uff0c\u5728\u5236\u9020\u6cd5\u9635\u91cc\u753b\u4e00\u628a\u624b\u67aa\u7684\u7b80\u7b14\u753b\u5236\u4f5c\u51fa\u4e00\u628a\u624b\u67aa\uff0c\u518d\u5236\u4f5c\u4e00\u679a\u5f39\u836f\u3002\u4e0b\u4e00\u6b65\u628a\u5f39\u836f\u653e\u5728\u590d\u5236\u6cd5\u9635\u4e2d\uff0c\u4e00\u5171\u590d\u52367\u6b21\u5373\u53ef\u5f97\u5230128\u53d1\u5b50\u5f39\u3002</p>"},{"location":"#_5","title":"\u70f9\u996a","text":"<p>\u7528\u70f9\u996a\u9505\uff08\u8010\u70ed\u7684\u5bb9\u5668\u5373\u53ef\uff09\u70f9\u996a\u98df\u6750\u53ef\u4ee5\u5f97\u5230\u98df\u7269\uff0c\u98df\u7528\u98df\u7269\u53ef\u4ee5\u586b\u9971\u809a\u5b50\uff0c\u8fd8\u53ef\u4ee5\u83b7\u5f97\u6c38\u4e45\u6027\u589e\u5f3a\u3002</p>"},{"location":"#_6","title":"\u70bc\u91d1","text":"<p>\u5728\u50ac\u5316\u6cd5\u9635\u4e2d\u5fc3\u70f9\u996a\u65f6\uff0c\u53ef\u4ee5\u6ce8\u5165\u9b54\u529b\u53c2\u4e0e\u53d1\u751f\u7279\u6b8a\u7684\u5316\u5b66\u53cd\u5e94\uff0c\u4ece\u800c\u5408\u6210\u51fa\u795e\u5947\u6d82\u6599\u3002\u795e\u5947\u6d82\u6599\u6307\u5177\u6709\u795e\u5947\u6027\u8d28\u7684\u6d82\u6599\uff0c\u6bd4\u5982\u53f6\u7eff\u6d82\u6599\uff08\u8ffd\u8e2a\uff09\u3001\u7075\u6db2\u6d82\u6599\uff08\u7834\u9632\uff09\u3001\u706b\u7130\u82b1\u7c89\uff08\u706b\u7130\u9644\u52a0\uff09\u3001\u9f9f\u58f3\u836f\u6c34\uff08\u4f7f\u7269\u54c1\u53d8\u5f97\u6c89\u91cd\u800c\u575a\u56fa\uff09\u3002\u5c06\u7269\u54c1\u4e0e\u795e\u5947\u6d82\u6599\u4e00\u8d77\u70f9\u996a\u6216\u8005\u5c06\u6d82\u6599\u62b9\u5728\u7269\u54c1\u8868\u9762\u53ef\u4ee5\u8ba9\u7269\u54c1\u5f97\u5230\u5bf9\u5e94\u7684\u795e\u5947\u6027\u8d28\u3002\u795e\u5947\u6d82\u6599\u5177\u6709\u4fdd\u8d28\u671f\uff0c\u79bb\u5f00\u80cc\u5305\u4e00\u6bb5\u65f6\u95f4\u540e\u4f1a\u5931\u53bb\u795e\u5947\u6027\u8d28\u3002</p>"},{"location":"%E5%89%A7%E6%83%85/","title":"\u5267\u60c5","text":"<p>\u7531\u4e8e\u5e73\u884c\u5b87\u5b99\u7684\u76f8\u4f3c\u6027\uff0c\u4eba\u7c7b\u6587\u660e\u5728\u5404\u79cd\u5e73\u884c\u5b87\u5b99\u4e2d\u7684\u53d1\u5c55\u8fdb\u7a0b\u90fd\u5927\u5dee\u4e0d\u5dee\uff0c\u53d1\u5c55\u51fa\u4e86\u73b0\u4ee3\u79d1\u5b66\u4f53\u7cfb\u3002\u800c\u6709\u4e00\u4e2a\u5e73\u884c\u5b87\u5b99\u7684\u53c2\u6570\u7a0d\u5fae\u6709\u70b9\u4e0d\u4e00\u6837\uff0c\u90a3\u91cc\u6ca1\u6709\u6b63\u5e38\u7684\u4eba\u7c7b\u6587\u660e\uff0c\u53ea\u6709\u201c\u5c0f\u9b54\u5973\u201d\u4eec\u5728\u90a3\u91cc\u5e73\u6de1\u800c\u5e78\u798f\u5730\u751f\u6d3b\u7740\u3002</p> <p>\u6839\u636e\u5c0f\u9b54\u5973\u7684\u4f20\u8bf4\uff0c\u5f88\u4e45\u5f88\u4e45\u4ee5\u524d\uff0c\u8fd9\u4e2a\u5e73\u884c\u5b87\u5b99\u91cc\u53ea\u6709\u5927\u9b54\u5973\u5b64\u96f6\u96f6\u4e00\u4e2a\u4eba\u5b58\u5728\u7740\u3002\u6ca1\u6709\u4eba\u8bb0\u5f97\u5979\u7684\u957f\u76f8\u3001\u6027\u683c\u3001\u8eab\u4e16\uff0c\u53ea\u77e5\u9053\u5979\u53eb\u8bfa\u4e9a\u3002\u6709\u4e00\u5929\uff0c\u8bfa\u4e9a\u611f\u5230\u5341\u5206\u65e0\u804a\uff0c\u5c31\u4ee5\u81ea\u5df1\u4e3a\u6a21\u677f\uff0c\u5229\u7528\u590d\u5236\u6cd5\u9635\u7684\u5347\u7ea7\u7248\u2014\u2014\u514b\u9686\u6cd5\u9635\u521b\u9020\u4e86\u4e00\u7fa4\u5c0f\u4eba\uff08\u76f8\u5bf9\u4e8e\u8bfa\u4e9a\u7684\u4f53\u578b\uff09\uff0c\u4e5f\u5c31\u662f\u540e\u6765\u7684\u5c0f\u9b54\u5973\u3002\u8bfa\u4e9a\u8fd0\u7528\u6cd5\u672f\u975e\u5e38\u719f\u7ec3\uff0c\u968f\u624b\u5c31\u753b\u51fa\u4e86\u514b\u9686\u6cd5\u9635\u3002\u4f46\u5979\u753b\u5230\u4e00\u534a\u65f6\u624b\u4e0d\u5c0f\u5fc3\u6296\u4e86\u4e00\u4e0b\uff0c\u514b\u9686\u6cd5\u9635\u5c31\u6709\u4e86\u7455\u75b5\uff0c\u5bfc\u81f4\u514b\u9686\u51fa\u6765\u7684\u5c0f\u9b54\u5973\u6709\u9ad8\u77ee\u80d6\u7626\uff0c\u90fd\u957f\u5f97\u548c\u5979\u4e0d\u592a\u4e00\u6837\u3002\u5c0f\u9b54\u5973\u4eec\u90fd\u7ee7\u627f\u4e86\u8bfa\u4e9a\u7684\u9b54\u529b\u548c\u9b54\u6cd5\u77e5\u8bc6\uff0c\u4e5f\u80fd\u591f\u719f\u7ec3\u5730\u753b\u51fa\u5404\u79cd\u6cd5\u9635\uff0c\u4f46\u4f3c\u4e4e\u90fd\u6709\u70b9\u61a8\u61a8\u7684\uff0c\u6ca1\u6cd5\u9886\u4f1a\u6cd5\u9635\u80cc\u540e\u7684\u539f\u7406\uff0c\u4e5f\u5c31\u6ca1\u6cd5\u5e2e\u52a9\u63a8\u8fdb\u5bf9\u9b54\u6cd5\u6216\u8005\u5b87\u5b99\u89c4\u5f8b\u7684\u7814\u7a76\u3002\u5bf9\u6b64\uff0c\u8bfa\u4e9a\u5728\u665a\u5e74\u611f\u5230\u5f88\u82e6\u607c\uff0c\u90c1\u90c1\u800c\u7ec8\u3002\u552f\u4e00\u8ba9\u8bfa\u4e9a\u5bbd\u6170\u7684\u662f\uff0c\u5373\u4f7f\u8981\u79bb\u5f00\u5979\u7684\u667a\u6167\uff0c\u5c0f\u9b54\u5973\u4eec\u4e5f\u6ca1\u6709\u653e\u5f03\u7814\u7a76\u9b54\u6cd5\u7684\u8fdb\u7a0b\u3002\u5979\u4eec\u4e0d\u77e5\u75b2\u5026\u5730\u5012\u817e\u5404\u79cd\u6cd5\u9635\u7684\u7ec4\u5408\uff0c\u8bd5\u56fe\u51ed\u501f\u8fd0\u6c14\u6216\u8005\u76f4\u89c9\u6765\u8bd5\u9a8c\u51fa\u66f4\u5f3a\u5927\u3001\u529f\u80fd\u66f4\u4e30\u5bcc\u7684\u6cd5\u9635\u3002\u5728\u5e38\u5e74\u7d2f\u6708\u7684\u7814\u7a76\u4e0b\uff0c\u5404\u79cd\u5b9e\u9a8c\u8bb0\u5f55\u5df2\u7ecf\u5806\u79ef\u6210\u5c71\uff0c\u751a\u81f3\u585e\u6ee1\u4e86\u4e16\u754c\u5404\u5730\u7684\u56fe\u4e66\u9986\u3002</p> <p>\u5176\u5b9e\u5c0f\u9b54\u5973\u4eec\u4e5f\u4e0d\u5f88\u7406\u89e3\u7814\u7a76\u9b54\u6cd5\u7684\u610f\u4e49\u662f\u4ec0\u4e48\uff0c\u53ea\u77e5\u9053\u8bfa\u4e9a\u4e34\u6b7b\u524d\u7ed9\u5979\u4eec\u8bb8\u4e0b\u7684\u5fc3\u613f\uff1a\u5408\u6210\u51fa\u80fd\u5c06\u77f3\u5934\u53d8\u6210\u91d1\u5b50\u7684\u70b9\u91d1\u77f3\u3002\u4f46\u53ea\u8981\u7a0d\u5fae\u4e86\u89e3\u4e00\u4e0b\u9b54\u6cd5\u7684\u7814\u7a76\u5386\u53f2\uff0c\u5c31\u77e5\u9053\u8fd9\u662f\u51e0\u4e4e\u4e0d\u53ef\u80fd\u7684\u3002\u56e0\u4e3a\u4ee5\u5f80\u6240\u6709\u7684\u6cd5\u672f\u90fd\u53ea\u53d1\u751f\u4e86\u5b8f\u89c2\u5c42\u9762\u7684\u53d8\u5316\uff0c\u5bf9\u4e8e\u5206\u5b50\u5c3a\u5ea6\u4ee5\u4e0b\u7684\u8fc7\u7a0b\u5219\u6ca1\u6709\u4e1d\u6beb\u529e\u6cd5\u3002\u800c\u5c06\u77f3\u5934\u53d8\u6210\u91d1\u5b50\uff0c\u672c\u8d28\u4e0a\u662f\u5c06\u4e00\u79cd\u539f\u5b50\u8f6c\u5316\u4e3a\u4e86\u53e6\u4e00\u79cd\u539f\u5b50\uff0c\u8fd9\u5728\u5b8f\u89c2\u7684\u6cd5\u672f\u4f53\u7cfb\u4e0b\u662f\u4e0d\u5b58\u5728\u7684\uff0c\u51ed\u501f\u5c0f\u9b54\u5973\u4eec\u7684\u5c0f\u8111\u74dc\uff0c\u4e5f\u5f88\u96be\u5bf9\u6cd5\u672f\u4f53\u7cfb\u505a\u51fa\u7a81\u7834\u3002\u56e0\u6b64\uff0c\u5728\u5927\u9b54\u5973\u6b7b\u540e\u7684\u51e0\u767e\u5e74\uff0c\u5c0f\u9b54\u5973\u4eec\u51e0\u4e4e\u6ca1\u6709\u5b9e\u8d28\u4e0a\u7684\u8fdb\u5c55\u3002</p> <p>\u76f4\u5230\u6709\u4e00\u5929\uff0c\u5c0f\u9b54\u5973\u4eec\u5c06\u4f20\u9001\u6cd5\u9635\u9b54\u6539\u5230\u4e86\u6781\u81f4\uff0c\u6210\u4e3a\u4e86\u4f4d\u9762\u8dc3\u8fc1\u6cd5\u9635\u3002\u5979\u4eec\u5728\u4e00\u4e2a\u6ca1\u6709\u5927\u6c14\u7684\u56fa\u4f53\u884c\u661f\u8868\u9762\u4f5c\u753b\uff0c\u56e0\u4e3a\u8fd9\u6837\u53ef\u4ee5\u624d\u53ef\u4ee5\u753b\u51fa\u8db3\u591f\u5927\u7684\u6cd5\u9635\uff0c\u800c\u4e14\u80fd\u4fdd\u5b58\u5f88\u957f\u65f6\u95f4\u3002\u5728\u628a\u661f\u7403\u8868\u9762\u5bc6\u5bc6\u9ebb\u9ebb\u753b\u6ee1\u5947\u5f62\u602a\u72b6\u7684\u7eb9\u8def\u4ee5\u540e\uff0c\u5979\u4eec\u6fc0\u6d3b\u4e86\u8fd9\u4e2a\u6cd5\u9635\uff0c\u5c06\u51e0\u540d\u63a2\u9669\u961f\u5458\u4f20\u9001\u5230\u4e86\u5176\u4e2d\u4e00\u4e2a\u666e\u901a\u7684\u5e73\u884c\u5b87\u5b99\u91cc\u3002\u5979\u4eec\u62b5\u8fbe\u65f6\uff0c\u53d1\u73b0\u4eba\u7c7b\u6587\u660e\u65e9\u5df2\u5728\u548cAI\u7684\u6218\u4e89\u4e2d\u540c\u5f52\u4e8e\u5c3d\uff0c\u53ea\u7559\u4e0b\u6b8b\u57a3\u65ad\u58c1\u548c\u5bf9\u6614\u65e5\u8f89\u714c\u7684\u53ea\u8a00\u7247\u8bed\uff0c\u4ee5\u53ca\u7531\u4e8e\u4e2d\u5fc3\u670d\u52a1\u5668\u88ab\u4eba\u7c7b\u731b\u70c8\u7684\u53cd\u6297\u51fb\u6bc1\u800c\u56db\u5904\u6e38\u8361\u7684\u5931\u63a7\u673a\u5668\u4eba\u3002\u5979\u4eec\u56db\u5904\u641c\u96c6\u524d\u6587\u660e\u7684\u8d44\u6599\uff0c\u5e76\u53d1\u73b0\u4ed6\u4eec\u7adf\u7136\u5bf9\u6838\u7269\u7406\u6709\u7740\u6df1\u5165\u7814\u7a76\uff0c\u751a\u81f3\u5df2\u7ecf\u5236\u9020\u51fa\u53ef\u4ee5\u4ea7\u751f\u65b0\u539f\u5b50\u7684\u673a\u5668\u2014\u2014\u7c92\u5b50\u5bf9\u649e\u673a\uff01\u63a2\u9669\u961f\u5458\u4eec\u559c\u51fa\u671b\u5916\uff0c\u628a\u8fd9\u4e2a\u597d\u6d88\u606f\u5e26\u56de\u5230\u4e86\u9b54\u5973\u5b87\u5b99\u3002\u4ece\u6b64\u4ee5\u540e\uff0c\u8d8a\u6765\u8d8a\u591a\u7684\u63a2\u9669\u961f\u542f\u7a0b\u524d\u5f80\u8fd9\u4e00\u4e2a\u4e16\u754c\uff0c\u5e76\u5c1d\u8bd5\u7740\u5e26\u56de\u524d\u6587\u660e\u7684\u8db3\u591f\u8d44\u6599\uff0c\u4ece\u800c\u590d\u539f\u51fa\u7c92\u5b50\u5bf9\u649e\u673a\uff0c\u5b9e\u73b0\u70b9\u77f3\u6210\u91d1\u7684\u68a6\u60f3\u3002</p> <p>\u4f60\u5c06\u626e\u6f14\u67d0\u4e2a\u63a2\u9669\u961f\u4e2d\u7684\u5176\u4e2d\u4e00\u5458\uff0c\u5f00\u542f\u8fd9\u573a\u8de8\u8d8a\u5b87\u5b99\u548c\u6587\u660e\u7684\u8d85\u7ea7\u8003\u53e4\u4e4b\u65c5\u3002</p>"},{"location":"%E6%B3%95%E9%98%B5/","title":"\u6cd5\u9635","text":"<p>\u6cd5\u9635\u662f\u4f7f\u7528\u9b54\u6cd5\u7684\u57fa\u7840\u8bbe\u65bd\u3002</p> <p>\u4e00\u822c\u800c\u8a00\uff0c\u6cd5\u9635\u901a\u8fc7\u7c89\u672b\u7ed8\u5236\u800c\u6210\uff0c\u7ed8\u5236\u5b8c\u6210\u540e\uff0c\u5c06\u9f20\u6807\u653e\u7f6e\u4e8e\u4e0a\u65b9\uff0c\u6309\u4e0b \u201cE\u201d \u952e\u4ee5\u542f\u7528\u6cd5\u9635\uff0c\u6b64\u65f6\u7c89\u672b\u4f1a\u6eb6\u89e3\uff0c\u5e76\u5728\u5730\u677f\u4e0a\u7559\u4e0b\u5370\u8bb0</p> <p>\u4e00\u90e8\u5206\u6cd5\u9635\u9700\u8981 \u201c\u9b54\u529b\u8f93\u5165\u201d \u6216 \u201c\u539f\u6599\u8f93\u5165\u201d</p> <p>\u957f\u6309 \u201cB\u201d \u952e\u4ee5\u4f7f\u7528\u8840\u6db2\u4f5c\u753b\uff0c\u8840\u6db2\u53ef\u4ee5\u8054\u901a\u6cd5\u9635(\u53ef\u4ee5\u7406\u89e3\u4e3a\u7535\u7ebf\u4e0e\u4f20\u9001\u5e26\u7684\u7ed3\u5408)</p>"},{"location":"%E6%B3%95%E9%98%B5/#_2","title":"\u6cd5\u9635\u7c7b\u578b","text":"<ul> <li>\u590d\u6d3b\u6cd5\u9635</li> </ul>"},{"location":"%E6%B3%95%E9%98%B5/#_3","title":"\u6280\u672f\u7ec6\u8282","text":"<p>\u6309\u4e0b \u201cE\u201d \u952e\u540e\uff0c\u5411\u671d\u5411\u65b9\u5411\u53d1\u5c04\u5c04\u7ebf\uff0c\u4ee5\u7b2c\u4e00\u4e2a\u78b0\u649e\u5230\u7684\u7c89\u672b\u7ebf\u6761\u4e3a\u57fa\u7840\uff0c\u6c42\u89e3\u51fa\u7ebf\u6761\u7684\u8054\u901a\u5757</p> <p>\u7d27\u63a5\u7740\uff0c\u7528\u4e00\u4e2a\u6700\u5c0f\u7684 \u6b63\u65b9\u5f62 \u5305\u56f4\u76d2\u5c06\u5176\u5305\u56f4\uff0c\u968f\u540e\u5c06\u7ebf\u6761\u6805\u683c\u5316\u81f3 256X256 \u7684\u56fe\u50cf\uff0c\u5728\u6b64\u57fa\u7840\u4e0a\u8dd1CNN\u6c42\u89e3\u51fa\u6cd5\u9635\u7c7b\u578b</p>"},{"location":"%E7%82%BC%E9%87%91/","title":"\u70bc\u91d1","text":""},{"location":"%E7%83%B9%E9%A5%AA/","title":"\u70f9\u996a","text":"<p>\u70f9\u996a\u53ef\u4ee5\u6062\u590d\u4f60\u7684\u9971\u98df\u5ea6\uff0c\u540c\u65f6\u53ef\u4ee5\u7ed9\u4e88\u4e00\u4e9b\u6c38\u4e45\u9762\u677f\u52a0\u6210\u3002</p>"},{"location":"%E7%A5%B7%E6%96%87/","title":"\u7977\u6587","text":""},{"location":"%E7%AC%A6%E5%92%92/","title":"\u7b26\u5492","text":""},{"location":"%E6%B3%95%E9%98%B5/%E5%A4%8D%E5%88%B6%E6%B3%95%E9%98%B5/","title":"\u590d\u5236\u6cd5\u9635","text":""},{"location":"%E6%B3%95%E9%98%B5/%E5%A4%8D%E5%88%B6%E6%B3%95%E9%98%B5/#_2","title":"\u6807\u51c6\u6a21\u7248","text":""},{"location":"%E6%B3%95%E9%98%B5/%E5%A4%8D%E5%88%B6%E6%B3%95%E9%98%B5/#_3","title":"\u6761\u4ef6","text":""},{"location":"%E6%B3%95%E9%98%B5/%E5%A4%8D%E5%88%B6%E6%B3%95%E9%98%B5/#_4","title":"\u7528\u9014","text":""},{"location":"%E6%B3%95%E9%98%B5/%E5%A4%8D%E6%B4%BB%E6%B3%95%E9%98%B5/","title":"\u590d\u6d3b\u6cd5\u9635","text":""},{"location":"%E6%B3%95%E9%98%B5/%E5%A4%8D%E6%B4%BB%E6%B3%95%E9%98%B5/#_2","title":"\u6807\u51c6\u6a21\u7248","text":""},{"location":"%E6%B3%95%E9%98%B5/%E5%A4%8D%E6%B4%BB%E6%B3%95%E9%98%B5/#_3","title":"\u6761\u4ef6","text":"<p>\u9b54\u529b\u6d88\u8017\uff1a\u65e0 \u539f\u6750\u6599\u4f9b\u5e94\uff1a\u65e0</p>"},{"location":"%E6%B3%95%E9%98%B5/%E5%A4%8D%E6%B4%BB%E6%B3%95%E9%98%B5/#_4","title":"\u7528\u9014","text":"<p>\u5c06\u4efb\u610f\u5c38\u4f53\u653e\u7f6e\u4e8e\u4e0a\u65b9\uff0c\u4e14\u5c38\u4f53\u6240\u5c5e\u7684\u7075\u9b42\u5904\u4e8e\u6e38\u8361\u72b6\u6001\uff0c\u5219\u81ea\u52a8\u590d\u6d3b\uff0c\u4e14\u6062\u590d\u4e00\u5207\u4f24\u53e3</p>"},{"location":"%E6%B3%95%E9%98%B5/%E5%A4%8D%E6%B4%BB%E6%B3%95%E9%98%B5/#_5","title":"\u8fdb\u9636\u6280\u5de7","text":"<p>\u914d\u5408 \u590d\u5236\u6cd5\u9635 \u514b\u9686\u51fa\u672c\u8eab\uff0c\u5e76\u5c06\u5176\u63d0\u524d\u5b89\u7f6e\u5728\u590d\u6d3b\u6cd5\u9635\u4e0a\u65b9\uff0c\u5219\u53ef\u4ee5\u8fbe\u5230\u201c\u6b7b\u4ea1\u540e\u7acb\u5373\u590d\u6d3b\u201d\u7684\u6548\u679c</p>"}]}